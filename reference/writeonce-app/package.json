{
  "name": "writeonce-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "dev": "ng serve -o --watch --configuration development",
    "devdoc": "ng serve --host 0.0.0.0 --watch --configuration development",
    "dstart": "ng serve --port=5200 --host 0.0.0.0",
    "start": "ng serve --host 0.0.0.0",
    "build": "ng build",
    "build:dev": "ng build --watch --deploy-url /my-app/ --base-href /my-app/ --configuration=development",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build-image": "docker build -t writeonce-frontend .",
    "remove-image": "docker rmi writeonce-frontend",
    "build-run-container": "docker compose up --build writeonce-frontend",
    "run-container": "docker compose up writeonce-frontend",
    "remove-container": "docker rm -f writeonce-frontend-container",
    "containerize": "npm run build-image && npm run run-container",
    "recontainerize": "npm run remove-container && npm run build-run-container",
    "reload-nginx": "docker exec writeonce-frontend-container nginx -s reload",
    "test-nginx": "docker exec writeonce-frontend-container nginx -t"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.8",
    "@angular/cdk": "^17.3.10",
    "@angular/common": "^18.2.8",
    "@angular/compiler": "^18.2.8",
    "@angular/core": "^18.2.8",
    "@angular/forms": "^18.2.8",
    "@angular/platform-browser": "^18.2.8",
    "@angular/platform-browser-dynamic": "^18.2.8",
    "@angular/router": "^18.2.8",
    "@fortawesome/angular-fontawesome": "^0.10.2",
    "@fortawesome/fontawesome-svg-core": "^6.4.0",
    "@fortawesome/free-brands-svg-icons": "^6.4.0",
    "@fortawesome/free-solid-svg-icons": "^6.4.0",
    "jest-editor-support": "*",
    "marked": "^12.0.2",
    "ngx-markdown": "^18.1.0",
    "prismjs": "^1.29.0",
    "run-script-os": "*",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.9",
    "@angular/cli": "^18.2.9",
    "@angular/compiler-cli": "^18.2.8",
    "@types/jasmine": "~5.1.0",
    "@types/marked": "^6.0.0",
    "@types/prismjs": "^1.26.4",
    "autoprefixer": "^10.4.19",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "~5.5.4"
  }
}
